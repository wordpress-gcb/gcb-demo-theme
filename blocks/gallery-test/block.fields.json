{
  "controls": [
    {
      "id": "panel_main",
      "type": "group",
      "label": "Gallery",
      "controlsGroup": "settings"
    },
    {
      "id": "ctrl_heading",
      "type": "text",
      "label": "Heading",
      "attributeKey": "heading",
      "default": "Our work",
      "controlsGroup": "settings",
      "parentPanelId": "panel_main"
    },
    {
      "id": "ctrl_images",
      "type": "gallery",
      "label": "Images",
      "attributeKey": "images",
      "controlsGroup": "settings",
      "parentPanelId": "panel_main"
    },
    {
      "id": "ctrl_columns",
      "type": "range",
      "label": "Columns (desktop)",
      "attributeKey": "columns",
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1,
      "controlsGroup": "settings",
      "parentPanelId": "panel_main"
    }
  ]
}
